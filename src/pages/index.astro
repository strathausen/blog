---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { SITE_TITLE } from "../consts";

const description = "philipp strathausen - berlin based senior full stack engineer. i help small teams ship faster by making the right architecture calls and integrating ai where it saves time. 16+ years building with typescript, next.js, python, and postgres.";
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={description} />
    <style>
      img.profile {
        float: right;
        margin-left: 2em;
        width: 300px;
        aspect-ratio: 540 / 438;
      }
      /* in small screens, don't float the image */
      @media only screen and (max-width: 600px) {
        img.profile {
          float: none;
          margin-left: 0;
          width: 100%;
          aspect-ratio: 540 / 438;
        }
      }
    </style>
  </head>

  <body>
    <div class="page-wrapper">
    <Header title={SITE_TITLE} />
    <main>
      <h1>hi there.</h1>
      <img alt="philipp strathausen - berlin based full stack developer" class="profile" src="/strathausen.jpeg" />

      <p>
        i'm philipp. i love building things.
      </p>

      <p>
        16+ years of experience in software development, i've co-founded
        <a href="https://www.fitanalytics.com">fit analytics</a> (scaled from prototype to market leader in online size recommendations),
        led teams at <a href="https://codepan.de">codepan</a> on projects for daimler, bosch, and wix,
        and most recently built ai-powered products for recruiting, financial compliance, and
        <a href="http://m-click.aero/">airspace management</a>.
      </p>

      <p>
        now working at <a href="https://www.elephantcompany.com">elephant</a>
      </p>

      <h2>get in touch</h2>
      <p>
        drop me a line at <a href="mailto:philipp@stratha.us"
          >philipp@stratha.us</a
        >.
      </p>
    </main>
    <Footer />
    </div>
  </body>
</html>
