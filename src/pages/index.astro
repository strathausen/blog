---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { SITE_TITLE } from "../consts";

const description = "philipp strathausen - berlin based senior full stack engineer. i help small teams ship faster by making the right architecture calls and integrating ai where it saves time. 16+ years building with typescript, next.js, python, and postgres.";
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={description} />
    <style>
      img.profile {
        float: right;
        margin-left: 2em;
        width: 300px;
        aspect-ratio: 540 / 438;
      }
      /* in small screens, don't float the image */
      @media only screen and (max-width: 600px) {
        img.profile {
          float: none;
          margin-left: 0;
          width: 100%;
          aspect-ratio: 540 / 438;
        }
      }
    </style>
  </head>

  <body>
    <div class="page-wrapper">
    <Header title={SITE_TITLE} />
    <main>
      <h1>hi there.</h1>
      <img alt="philipp strathausen - berlin based full stack developer" class="profile" src="/strathausen.jpeg" />

      <p>
        i'm philipp — i help small engineering teams ship faster by making
        the right architecture calls, clearing blockers, and integrating ai
        where it actually saves time.
      </p>

      <p>
        with 16+ years of experience, i've co-founded
        <a href="https://www.fitanalytics.com">fit analytics</a> (scaled from prototype to market leader in online size recommendations),
        led teams at <a href="https://codepan.de">codepan</a> on projects for daimler, bosch, and wix,
        and most recently built ai-powered products for recruiting, financial compliance, and
        <a href="http://m-click.aero/">airspace management</a>.
      </p>

      <h2>what i do</h2>
      <ul>
        <li><strong>take products from mvp to scalable platform</strong> — i've done it multiple times, from early-stage prototypes to data-driven web apps serving millions</li>
        <li><strong>integrate ai into real workflows</strong> — document processing, candidate screening, compliance checks — not demos, but systems that replace manual work</li>
        <li><strong>lead small teams</strong> — i prioritize, translate stakeholder needs into tech requirements, and create focus so the team ships</li>
      </ul>

      <p>
        my stack: <strong>typescript</strong>, <strong>next.js</strong>, <strong>react</strong>,
        <strong>python</strong>, <strong>django</strong>, <strong>fastapi</strong>,
        and <strong>postgres</strong>. i anticipate challenges, clear obstacles before they
        slow progress, and create environments where teams do their best work.
      </p>

      <h2>side projects</h2>
      <p>
        i build tools that solve real problems:
        <a href="https://www.thefoodie.space">thefoodie.space</a> (next.js + ai data pipeline — auto-syncs tiktok content, generates structured recipes),
        <a href="https://www.commentable.space">commentable.space</a> (self-hosted commenting with ai moderation),
        <a href="https://www.laundryroom.social">laundryroom.social</a> (a free meetup alternative),
        <a href="https://www.pleeboo.com">pleeboo</a> (who-brings-what for community events),
        and <a href="https://4fram.es">4fram.es</a> (lomo gif maker).
      </p>

      <h2>writing</h2>
      <p>
        i write about building software, shipping side projects, and ai integrations.
        check out my <a href="/blog">blog</a>.
      </p>

      <h2>get in touch</h2>
      <p>
        need a senior hand to get your team moving?
        drop me a line at <a href="mailto:philipp@stratha.us"
          >philipp@stratha.us</a
        >.
      </p>
    </main>
    <Footer />
    </div>
  </body>
</html>
